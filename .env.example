# Copy to `.env` for local development (never commit real secrets).
# Used by the FastAPI app (`vantage-api` / `python -m vantage_api`) when `[api]` extra is installed.

# --- API server (optional; defaults are safe for local dev) ---
VANTAGE_API_HOST=127.0.0.1
VANTAGE_API_PORT=8000
VANTAGE_API_RELOAD=false
VANTAGE_LOG_LEVEL=info

# Local directory for uploads, job state, and artifacts (future).
VANTAGE_DATA_DIR=./var/vantage

# Upload limits (API)
VANTAGE_MAX_UPLOAD_BYTES=104857600
VANTAGE_MAX_FILES_PER_JOB=50

# Chunking (optional overrides; defaults match pipeline ChunkingConfig)
# VANTAGE_CHUNK_MIN_WORDS=500
# VANTAGE_CHUNK_MAX_WORDS=2000
# VANTAGE_CHUNK_TARGET_LOW=1200
# VANTAGE_CHUNK_TARGET_HIGH=1500
# VANTAGE_CHUNK_OVERLAP_LOW=100
# VANTAGE_CHUNK_OVERLAP_HIGH=200

# --- Future integrations ---
# VANTAGE_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/vantage
# VANTAGE_REDIS_URL=redis://localhost:6379/0
# VANTAGE_S3_ENDPOINT=http://localhost:9000
# VANTAGE_S3_BUCKET=vantage-preprocess
